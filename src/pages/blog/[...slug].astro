---
import Layout from "../../layouts/Layout.astro";
import Comments from "../../components/Comments.astro";
import Newsletter from "../../components/Newsletter.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: post,
    }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content, headings } = await post.render();

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const words = post.body.split(/\s+/).length;
const readingTime = Math.ceil(words / 200);
---

<Layout
    title={post.data.title}
    description={post.data.description}
    image={post.data.image}
    type="article"
>
    <main
        class="flex-1 pt-32 pb-24 text-quartz dark:text-quartz-light overflow-x-hidden"
    >
        <!-- Header Section -->
        <div class="max-w-5xl mx-auto px-4 md:px-6">
            <header class="mb-12">
                <h1
                    class="text-3xl md:text-5xl font-sans font-black mb-8 leading-tight tracking-tight text-quartz dark:text-quartz-light"
                >
                    {post.data.title}
                </h1>

                <p
                    class="text-md md:text-lg text-quartz/70 dark:text-quartz-light/70 leading-relaxed max-w-3xl"
                >
                    {post.data.description}
                </p>
            </header>
        </div>

        <!-- Metadata Section: True edge-to-edge lines -->
        <div
            class="w-full border-y border-quartz/10 dark:border-quartz-light/10 mb-16 py-8"
        >
            <div class="max-w-5xl mx-auto px-4 md:px-6">
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
                    <div>
                        <span
                            class="block text-[10px] font-bold uppercase tracking-widest text-quartz/40 dark:text-quartz-light/40 mb-2"
                            >Authors</span
                        >
                        <span class="text-sm font-medium"
                            >{post.data.author || "Léonel VODOUNOU"}</span
                        >
                    </div>
                    <div>
                        <span
                            class="block text-[10px] font-bold uppercase tracking-widest text-quartz/40 dark:text-quartz-light/40 mb-2"
                            >Affiliations</span
                        >
                        <span class="text-sm font-medium"
                            >Mathematical Engineering & AI</span
                        >
                    </div>
                    <div>
                        <span
                            class="block text-[10px] font-bold uppercase tracking-widest text-quartz/40 dark:text-quartz-light/40 mb-2"
                            >Published</span
                        >
                        <span class="text-sm font-medium">{formattedDate}</span>
                    </div>
                    <div>
                        <span
                            class="block text-[10px] font-bold uppercase tracking-widest text-quartz/40 dark:text-quartz-light/40 mb-2"
                            >Read Time</span
                        >
                        <span class="text-sm font-medium"
                            >{readingTime} min read</span
                        >
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="max-w-5xl mx-auto px-4 md:px-6">
            <div class="flex flex-col lg:flex-row gap-0">
                <!-- Sidebar TOC - Desktop only -->
                <aside
                    class="hidden lg:block w-[240px] flex-shrink-0 pr-12 border-r border-quartz/10 dark:border-quartz-light/10"
                >
                    <div class="sticky top-32">
                        <TableOfContents headings={headings} />
                    </div>
                </aside>

                <!-- Article & Mobile TOC -->
                <div class="flex-1 min-w-0 lg:pl-16">
                    <!-- Mobile TOC: Boxed style -->
                    <div
                        class="lg:hidden mb-12 p-8 border border-quartz/10 dark:border-quartz-light/10 bg-quartz/[0.02] dark:bg-white/[0.02] rounded-lg"
                    >
                        <TableOfContents headings={headings} />
                    </div>

                    <article
                        class="prose prose-lg dark:prose-invert max-w-none
                        prose-headings:font-sans prose-headings:text-quartz dark:prose-headings:text-quartz-light prose-headings:scroll-mt-32
                        prose-h1:font-black prose-h2:font-extrabold prose-h2:border-b prose-h2:border-quartz/10 dark:prose-h2:border-quartz-light/10 prose-h2:pb-4 prose-h2:mt-10 prose-h2:mb-6
                        prose-h3:font-bold prose-h3:mt-8 prose-h3:mb-4
                        prose-p:text-quartz/90 dark:prose-p:text-quartz-light/90 prose-p:leading-normal prose-p:mb-6 prose-p:text-justify
                        prose-a:text-quartz-accent dark:prose-a:text-quartz-accent prose-a:font-medium prose-a:no-underline hover:prose-a:underline
                        prose-strong:text-quartz dark:prose-strong:text-quartz-light
                        prose-code:text-quartz-accent dark:prose-code:text-quartz-accent prose-code:bg-quartz/5 dark:prose-code:bg-quartz-light/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
                        prose-pre:bg-quartz/5 dark:prose-pre:bg-black/40 prose-pre:border prose-pre:border-quartz/10 dark:prose-pre:border-quartz-light/10
                        prose-blockquote:border-l-quartz-accent prose-blockquote:bg-quartz/5 dark:prose-blockquote:bg-quartz-accent/5 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:rounded-r prose-blockquote:italic
                        prose-ul:list-disc prose-ol:list-decimal
                        prose-img:rounded-xl prose-img:shadow-2xl mb-24"
                    >
                        <Content />
                    </article>

                    <!-- Newsletter & Comments Section -->
                    <div
                        class="border-t border-quartz/10 dark:border-quartz-light/10 pt-16"
                    >
                        <Newsletter />
                        <Comments />
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>
