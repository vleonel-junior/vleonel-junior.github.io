---
import type { MarkdownHeading } from "astro";

interface Props {
    headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Filter headings to only show h2 and h3
const filteredHeadings = headings.filter(
    (heading) => heading.depth >= 2 && heading.depth <= 3,
);

// Build numbered structure: h2 gets 1.1, 1.2... h3 gets indented under parent h2
let h2Counter = 0;
let h3Counter = 0;

const numberedHeadings = filteredHeadings.map((heading) => {
    if (heading.depth === 2) {
        h2Counter++;
        h3Counter = 0;
        return { ...heading, number: `${h2Counter}` };
    } else {
        h3Counter++;
        return { ...heading, number: `${h2Counter}.${h3Counter}` };
    }
});
---

<nav class="toc-container" aria-label="Table of Contents">
    <h2 class="toc-header">Contents</h2>
    <ul class="toc-list">
        {
            numberedHeadings.map((heading) => (
                <li
                    class={`toc-item ${heading.depth > 2 ? "toc-item--sub" : "toc-item--main"}`}
                >
                    <a
                        href={`#${heading.slug}`}
                        class="toc-link"
                        data-toc-link
                        data-depth={heading.depth}
                    >
                        <span class="toc-number">{heading.number}</span>
                        <span class="toc-text">{heading.text}</span>
                    </a>
                </li>
            ))
        }
    </ul>
</nav>

<script>
    // Improved scroll spy with better active section tracking
    function initTOC() {
        const tocLinks = document.querySelectorAll("[data-toc-link]");
        const headings = document.querySelectorAll("article h2, article h3");

        if (!tocLinks.length || !headings.length) return;

        let activeLink: Element | null = null;

        function setActive(id: string | null) {
            if (!id) return;

            tocLinks.forEach((link) => {
                link.classList.remove("toc-link--active");
            });

            const target = document.querySelector(
                `a[data-toc-link][href="#${id}"]`
            );
            if (target) {
                target.classList.add("toc-link--active");
                activeLink = target;
            }
        }

        const observer = new IntersectionObserver(
            (entries) => {
                // Find the first visible heading
                const visibleEntries = entries
                    .filter((entry) => entry.isIntersecting)
                    .sort(
                        (a, b) =>
                            a.boundingClientRect.top - b.boundingClientRect.top
                    );

                if (visibleEntries.length > 0) {
                    const id =
                        visibleEntries[0].target.getAttribute("id");
                    setActive(id);
                }
            },
            {
                rootMargin: "-80px 0px -60% 0px",
                threshold: [0, 0.5, 1],
            }
        );

        headings.forEach((heading) => {
            observer.observe(heading);
        });

        // Set first heading as active initially
        if (headings.length > 0) {
            const firstId = headings[0].getAttribute("id");
            setActive(firstId);
        }
    }

    // Run on page load
    initTOC();

    // Also run on Astro page transitions
    document.addEventListener("astro:after-swap", initTOC);
</script>

<style>
    .toc-container {
        max-height: calc(100vh - 10rem);
        overflow-y: auto;
        padding-right: 0.5rem;
    }

    .toc-header {
        font-family: var(--font-sans), system-ui, sans-serif;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-primary);
        opacity: 0.5;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--border-primary);
    }

    .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
    }

    .toc-item {
        margin: 0;
        padding: 0;
    }

    .toc-link {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        padding: 0.375rem 0.5rem;
        border-radius: 0.375rem;
        border-left: 2px solid transparent;
        text-decoration: none;
        transition: all 0.2s ease;
        color: var(--text-primary);
        opacity: 0.5;
        font-size: 0.8rem;
        line-height: 1.4;
    }

    .toc-item--sub .toc-link {
        padding-left: 1.5rem;
        font-size: 0.75rem;
        opacity: 0.4;
    }

    .toc-link:hover {
        opacity: 0.85;
        background: var(--border-primary);
    }

    .toc-link--active {
        opacity: 1 !important;
        border-left-color: #2563eb;
        background: rgba(37, 99, 235, 0.06);
    }

    :global(.dark) .toc-link--active {
        border-left-color: #60a5fa;
        background: rgba(96, 165, 250, 0.08);
    }

    .toc-number {
        flex-shrink: 0;
        font-family: var(--font-sans), system-ui, sans-serif;
        font-weight: 700;
        font-size: 0.7rem;
        min-width: 1.25rem;
        color: inherit;
        opacity: 0.7;
    }

    .toc-item--sub .toc-number {
        font-size: 0.65rem;
    }

    .toc-text {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-family: var(--font-sans), system-ui, sans-serif;
        font-weight: 500;
    }

    .toc-link--active .toc-number,
    .toc-link--active .toc-text {
        font-weight: 700;
    }

    /* Custom scrollbar */
    .toc-container::-webkit-scrollbar {
        width: 3px;
    }
    .toc-container::-webkit-scrollbar-track {
        background: transparent;
    }
    .toc-container::-webkit-scrollbar-thumb {
        background: rgba(156, 163, 175, 0.2);
        border-radius: 2px;
    }
    .toc-container::-webkit-scrollbar-thumb:hover {
        background: rgba(156, 163, 175, 0.4);
    }
</style>
