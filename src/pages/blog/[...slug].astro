---
import Layout from "../../layouts/Layout.astro";
import Comments from "../../components/Comments.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: post,
    }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content, headings } = await post.render();

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<Layout
    title={post.data.title}
    description={post.data.description}
    image={post.data.image}
    type="article"
>
    <main class="flex-1 pt-32 pb-24 text-quartz dark:text-quartz-light">
        <div class="container-custom max-w-7xl mx-auto px-4 md:px-6">
            <!-- Header Section: Aligned with the body column -->
            <div class="lg:ml-[240px] lg:pl-16 mb-16">
                <header>
                    <h1
                        class="text-4xl md:text-5xl font-sans font-bold mb-8 leading-tight tracking-tight text-quartz dark:text-quartz-light"
                    >
                        {post.data.title}
                    </h1>

                    <p
                        class="text-lg md:text-xl text-quartz/70 dark:text-quartz-light/70 leading-relaxed mb-12 max-w-3xl"
                    >
                        {post.data.description}
                    </p>

                    <!-- Metadata Grid -->
                    <div class="grid grid-cols-2 lg:grid-cols-3 gap-8 pb-12">
                        <div>
                            <span
                                class="block text-[10px] font-bold uppercase tracking-widest text-quartz/40 dark:text-quartz-light/40 mb-2"
                                >Authors</span
                            >
                            <span class="text-sm font-medium"
                                >{post.data.author || "Léonel VODOUNOU"}</span
                            >
                        </div>
                        <div>
                            <span
                                class="block text-[10px] font-bold uppercase tracking-widest text-quartz/40 dark:text-quartz-light/40 mb-2"
                                >Affiliations</span
                            >
                            <span class="text-sm font-medium"
                                >Mathematical Engineering & AI</span
                            >
                        </div>
                        <div>
                            <span
                                class="block text-[10px] font-bold uppercase tracking-widest text-quartz/40 dark:text-quartz-light/40 mb-2"
                                >Published</span
                            >
                            <span class="text-sm font-medium"
                                >{formattedDate}</span
                            >
                        </div>
                    </div>
                </header>
            </div>

            <!-- Horizontal Divider -->
            <div
                class="border-t border-quartz/10 dark:border-quartz-light/10 mb-16"
            >
            </div>

            <!-- Main Content Split -->
            <div class="grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-0">
                <!-- Sidebar (TOC) - Left side with vertical divider -->
                <aside
                    class="hidden lg:block pr-12 border-r border-quartz/10 dark:border-quartz-light/10"
                >
                    <div class="sticky top-32">
                        <TableOfContents headings={headings} />
                    </div>
                </aside>

                <!-- Article Content Column -->
                <div class="min-w-0 lg:pl-16">
                    <article
                        class="prose prose-lg dark:prose-invert max-w-3xl
                        prose-headings:font-sans prose-headings:font-bold prose-headings:text-quartz dark:prose-headings:text-quartz-light prose-headings:scroll-mt-32
                        prose-p:text-quartz/90 dark:prose-p:text-quartz-light/90 prose-p:leading-relaxed prose-p:mb-8 text-justify
                        prose-a:text-quartz-accent dark:prose-a:text-quartz-accent prose-a:font-medium prose-a:no-underline hover:prose-a:underline
                        prose-strong:text-quartz dark:prose-strong:text-quartz-light
                        prose-code:text-quartz-accent dark:prose-code:text-quartz-accent prose-code:bg-quartz/5 dark:prose-code:bg-quartz-light/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
                        prose-pre:bg-quartz/5 dark:prose-pre:bg-black/40 prose-pre:border prose-pre:border-quartz/10 dark:prose-pre:border-quartz-light/10
                        prose-blockquote:border-l-quartz-accent prose-blockquote:bg-quartz/5 dark:prose-blockquote:bg-quartz-accent/5 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:rounded-r prose-blockquote:italic
                        prose-ul:list-disc prose-ol:list-decimal
                        prose-img:rounded-xl prose-img:shadow-2xl mb-24"
                    >
                        <Content />
                    </article>

                    <!-- Comments Section -->
                    <div
                        class="max-w-3xl border-t border-quartz/10 dark:border-quartz-light/10 pt-16"
                    >
                        <Comments />
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>
